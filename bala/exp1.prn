   a=float(input("enter the side 1:"))
   b=float(input("enter the side 2:"))
   c=float(input("enter the side 3:"))
   if(a>0 and b>0 and c>0):
      s=(a+b+c)/2
      area=(s*(s-a)*(s-b)*(s-c))**0.5
      print("area =",area)
   else:
      print("invalid input")
else:
