#!/BIN/BASH
ECHO -N "ENTRE THE NAME OF THE COUNTRY"
READ COUNTRY
ECHO - "THE OFFICIAL LANGUAGE OF THE $COUNTRY IS"
CASE $COUNTRY IN
   LITHUANIA)
      ECHO -N "LITHUNIAN"
      ;;
   ROMAIN)
      ECHO -N "ROMIANIA"
      ;;
   ITALY)
      ECHO -N "ITALIAN"
      ;;
   *)
      ECHO -N "UNKNOWN"
      ;;
ESAC
