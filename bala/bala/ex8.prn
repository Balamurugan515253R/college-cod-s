[23bee033@mepcolinux bala]$cat reverse.sh
echo "entre a number "
read n
num=0
while [ $n -gt 0 ]
do
   num=$(expr $num \* 10)
   k=$(expr $n % 10)
   num=$(expr $num + $k)
   n=$(expr $n / 10)
done
echo "reversed number : $num"


